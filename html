<!DOCTYPE html>
<html lang="ne">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Premium Blend | Coffee Shop</title>
    <style>
        /* [Commit 2: Global Styles & Theme Colors Setup] */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            scroll-behavior: smooth;
        }

        :root {
            --primary-color: #4a3424; 
            --secondary-color: #d4a373; 
            --accent-color: #faedcd; 
            --dark-color: #2b1e16;
            --light-color: #fcf8f2;
        }

        body {
            background-color: var(--light-color);
            color: #333;
            line-height: 1.6;
        }

        /* [Commit 3: Navigation Header Bar styling] */
        header {
            background-color: var(--primary-color);
            padding: 15px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        header .logo {
            font-size: 24px;
            font-weight: bold;
            color: var(--secondary-color);
        }

        header nav a {
            color: #fff;
            text-decoration: none;
            margin-left: 20px;
            transition: color 0.3s;
        }

        header nav a:hover {
            color: var(--secondary-color);
        }

        /* [Commit 4: Hero Dynamic Banner Layout] */
        .hero {
            background: linear-gradient(rgba(0, 0, 0, 0.65), rgba(0, 0, 0, 0.65)), 
                        url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&q=80&w=1200') no-repeat center center/cover;
            height: 65vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: #fff;
            padding: 0 20px;
        }

        .hero h1 {
            font-size: 45px;
            margin-bottom: 10px;
            color: var(--accent-color);
        }

        .hero p {
            font-size: 18px;
            margin-bottom: 20px;
        }

        .hero .btn {
            background-color: var(--secondary-color);
            color: #333;
            padding: 10px 25px;
            text-decoration: none;
            font-weight: bold;
            border-radius: 20px;
            transition: 0.3s;
        }

        .hero .btn:hover {
            background-color: var(--accent-color);
        }

        /* [Commit 5: About Us Content Blocks] */
        .about-section {
            padding: 60px 5%;
            background-color: #fff;
            text-align: center;
        }

        .about-section h2 {
            font-size: 32px;
            color: var(--primary-color);
            margin-bottom: 15px;
        }

        .about-section p {
            max-width: 700px;
            margin: 0 auto;
            color: #666;
        }

        /* [Commit 6: Menu Section Matrix/Grid Layout] */
        .menu-section {
            padding: 60px 5%;
            text-align: center;
        }

        .menu-section h2 {
            font-size: 32px;
            color: var(--primary-color);
            margin-bottom: 30px;
        }

        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 25px;
        }

        .menu-item {
            background-color: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.05);
        }

        .menu-item img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-radius: 5px;
            margin-bottom: 15px;
        }

        .menu-item h3 {
            color: var(--primary-color);
            margin-bottom: 8px;
        }

        .menu-item .price {
            color: var(--secondary-color);
            font-weight: bold;
            font-size: 18px;
        }

        /* [Commit 7: Open Timing Cards Widget] */
        .info-section {
            background-color: var(--dark-color);
            color: #fff;
            padding: 40px 5%;
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 20px;
            text-align: center;
        }

        .info-box h3 {
            color: var(--secondary-color);
            margin-bottom: 10px;
        }

        /* [Commit 8: Interactive Order Layout Block] */
        .order-section {
            padding: 60px 5%;
            background-color: var(--accent-color);
            text-align: center;
        }

        .order-container {
            max-width: 500px;
            margin: 0 auto;
            background: #fff;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .form-group {
            margin-bottom: 15px;
            text-align: left;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            color: var(--primary-color);
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }

        .order-btn {
            width: 100%;
            background-color: var(--primary-color);
            color: white;
            padding: 12px;
            border: none;
            border-radius: 5px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
        }

        /* [Commit 10: Footer block layout template] */
        footer {
            background-color: var(--dark-color);
            color: #aaa;
            text-align: center;
            padding: 20px;
            font-size: 14px;
        }
    </style>
</head>
<body>

    <!-- [Commit 3: Main Navbar Components] -->
    <header>
        <div class="logo">☕ The Premium Blend</div>
        <nav>
            <a href="#home">Home</a>
            <a href="#about">About</a>
            <a href="#menu">Menu</a>
            <a href="#hours">Hours</a>
            <a href="#order">Order</a>
        </nav>
    </header>

    <!-- [Commit 4: Hero Marketing Element Content] -->
    <section class="hero" id="home">
        <h1>Haripraharko Taza Coffee</h1>
        <p>Premium organic Himalayan beans bata tayar parieko utkrishna coffee swad.</p>
        <a href="#order" class="btn">Order Now</a>
    </section>

    <!-- [Commit 5: Historical Narrative Profile] -->
    <section class="about-section" id="about">
        <h2>Hamro Katha (Our Story)</h2>
        <p>Hami Nepal ka uccha pahadi bhaegharu bata sankalan gariye ka high-quality organic coffee beans matra prayog garchhau. San 2018 dekhi hami tapaiharulai daju-bhai ra sathi-bhai haru sanga basera ramaune euta shanta ra aakarshak vatavaran pradan gardai aayeka chhau.</p>
    </section>

    <!-- [Commit 6: Inventory Menu Products Matrix] -->
    <section class="menu-section" id="menu">
        <h2>Hamro Special Menu</h2>
        <div class="menu-grid">
            <div class="menu-item">
                <img src="https://images.unsplash.com/photo-1510707577719-5d6872020595?auto=format&fit=crop&q=80&w=400" alt="Espresso">
                <h3>Rich Espresso</h3>
                <p class="price">Rs. 120</p>
            </div>
            <div class="menu-item">
                <img src="https://images.unsplash.com/photo-1572442388796-11668a67e53d?auto=format&fit=crop&q=80&w=400" alt="Cappuccino">
                <h3>Creamy Cappuccino</h3>
                <p class="price">Rs. 180</p>
            </div>
            <div class="menu-item">
                <img src="https://images.unsplash.com/photo-1517701604599-bb29b565090c?auto=format&fit=crop&q=80&w=400" alt="Latte">
                <h3>Caramel Iced Latte</h3>
                <p class="price">Rs. 220</p>
            </div>
        </div>
    </section>

    <!-- [Commit 7: Logistics Timings Component Block] -->
    <section class="info-section" id="hours">
        <div class="info-box">
            <h3>⏰ Opening Hours</h3>
            <p>Suntol - Sukrabaar: 7:00 AM - 9:00 PM</p>
            <p>Sanibaar: 8:00 AM - 10:00 PM</p>
        </div>
        <div class="info-box">
            <h3>📍 Location</h3>
            <p>New Baneshwor, Kathmandu, Nepal</p>
        </div>
    </section>

    <!-- [Commit 8: Custom Dynamic Orders Entry Form Element] -->
    <section class="order-section" id="order">
        <h2>Online Order Garnuhos</h2>
        <div class="order-container">
            <form id="coffeeOrderForm">
                <div class="form-group">
                    <label for="name">Tapai ko Naam</label>
                    <input type="text" id="name" required placeholder="Ex: Ram Bahadur">
                </div>
                <div class="form-group">
                    <label for="coffeeType">Coffee Type</label>
                    <select id="coffeeType" required>
                        <option value="Espresso">Rich Espresso - Rs. 120</option>
                        <option value="Cappuccino">Creamy Cappuccino - Rs. 180</option>
                        <option value="Iced Latte">Caramel Iced Latte - Rs. 220</option>
                    </select>
                </div>
                <button type="submit" class="order-btn">Place Order</button>
            </form>
        </div>
    </section>

    <!-- [Commit 10: Base Standard Legal Layout] -->
    <footer>
        <p>&copy; 2026 The Premium Blend Cafe. All Rights Reserved.</p>
    </footer>

    <!-- [Commit 9: Application Scripts Handler Logic Alert] -->
    <script>
        document.getElementById('coffeeOrderForm').addEventListener('submit', function(event) {
            event.preventDefault();
            const clientName = document.getElementById('name').value;
            const item = document.getElementById('coffeeType').value;
            alert(`Dhanyabad ${clientName}! Tapai ko 1 Cup ${item} ko order successfully sent vayo.`);
            this.reset();
        });
    </script>
</body>
</html>